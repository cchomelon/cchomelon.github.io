---
layout: base.njk
title: Home
han: false
---

{% set posts = collections.post | reverse %}
{% set categoryGroups = posts | groupByCategory %}
{% if posts | length %}
  {% set currentPost = posts[0] %}
  {% set currentContent = currentPost.templateContent %}
  {% set currentTocItems = currentPost.templateContent | tocFromHtml %}
  {% set panelTitle = "Latest Blog Entry" %}
  {% include "post-shell.njk" %}
{% else %}
  <div class="profile-header">
    <div class="profile-name">
      <span class="font-comic">schizo</span><span class="font-mono">posting</span>
    </div>
    <div class="profile-status"><span class="font-DOS">0x5F3759DF</span></div>
  </div>

  <div class="panel" style="margin-top: 12px;">
    <div class="panel-title">Latest Blog Entry</div>
    <div class="panel-body">
      <p>No posts yet.</p>
    </div>
  </div>
{% endif %}
